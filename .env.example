# Database (Neon in production)
DATABASE_URL=postgresql://user:password@host/dbname
# Set to "pg" to use node-postgres against a local/standard Postgres for
# development or integration tests (the Neon HTTP driver can't reach localhost).
# Leave UNSET in production.
DATABASE_DRIVER=

# Supabase (file storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
# Optional model overrides (defaults: sonnet-4-6 for analysis, haiku-4.5 for
# skill extraction). Set the analyst to claude-opus-4-8 for maximum quality.
SCOPE_ANALYST_MODEL=
SKILL_EXTRACT_MODEL=

# Resend (email)
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# REQUIRED in production (>= 32 chars). The app refuses to boot in production
# without a strong secret — there is no insecure fallback.
JWT_SECRET=your-jwt-secret-at-least-32-chars
# Optional: separate secret for agent tokens; falls back to JWT_SECRET.
AGENT_TOKEN_SECRET=
